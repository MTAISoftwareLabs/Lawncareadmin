# ===========================================
# Lawncare Workshop - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to version control

# ===========================================
# DATABASE CONFIGURATION (Required)
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/lawncare_workshop
PGHOST=localhost
PGPORT=5432
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGDATABASE=lawncare_workshop

# ===========================================
# AUTHENTICATION (Required)
# ===========================================
JWT_SECRET=your-super-secure-jwt-secret-key-change-in-production
SESSION_SECRET=your-super-secure-session-secret-change-in-production

# ===========================================
# FILE / MEDIA STORAGE
# ===========================================
# Default is local/server disk storage — uploaded media (chat images, etc.)
# is written to the directory below and served from /objects/*.
# This is what you want on a normal VPS / self-hosted server.
STORAGE_MODE=local
# Optional: where uploaded files are stored on disk (defaults to ./uploads-objects).
# Use an absolute path on a persistent volume in production.
LOCAL_STORAGE_DIR=/var/www/lawncare/uploads-objects

# --- Replit Object Storage (ONLY when hosting on Replit) ---
# Leave STORAGE_MODE=local for a normal server. To use Replit Object Storage,
# set STORAGE_MODE=replit and provide the values below (Replit sets these for you).
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=your_bucket_id
# PUBLIC_OBJECT_SEARCH_PATHS=/objects
# PRIVATE_OBJECT_DIR=/private

# Public site URL used for Stripe redirect URLs (local: http://localhost:5000)
APP_URL=http://localhost:5000

# ===========================================
# STRIPE PAYMENT INTEGRATION (Optional)
# ===========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_MONTHLY_PRICE_ID=price_monthly_id
STRIPE_YEARLY_PRICE_ID=price_yearly_id

# ===========================================
# FIREBASE PUSH NOTIFICATIONS (Optional)
# ===========================================
# Download service account JSON from Firebase Console
# Project Settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key Here\n-----END PRIVATE KEY-----"

# ===========================================
# OPENAI API (For AI Turf Talk / mobile app)
# ===========================================
# Optional: configure in Admin → Settings → AI / OpenAI instead.
# Admin panel settings take precedence over this env var.
OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ===========================================
# REPLIT SPECIFIC (Auto-configured on Replit)
# ===========================================
REPLIT_DOMAINS=your-repl.replit.dev
REPLIT_DEV_DOMAIN=your-repl.replit.dev
REPL_ID=your-repl-id

# Optional: WeatherAPI.com key for /api/weather and soil temp banners (or set in Admin → Integrations).
WEATHER_API_KEY=your-weatherapi-key
NODE_ENV=development
PORT=3000

# ===========================================
# SUBSCRIPTION PRICING (Defaults in code)
# ===========================================
MONTHLY_PRICE=9.99
YEARLY_PRICE=89.99
FREE_TRIAL_DAYS=7
